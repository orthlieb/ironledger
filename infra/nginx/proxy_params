# Copy to /etc/nginx/proxy_params on the server.
# This file is included by every proxy_pass location block.

proxy_http_version 1.1;

# Pass the real client IP to Node so rate limiting and security logs work
proxy_set_header X-Real-IP          $remote_addr;
proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto  $scheme;
proxy_set_header Host               $http_host;

# Required for WebSockets (not used now, but good to have ready)
proxy_set_header Upgrade            $http_upgrade;
proxy_set_header Connection         "upgrade";

# Timeouts — generous but not unlimited
proxy_connect_timeout 10s;
proxy_send_timeout    30s;
proxy_read_timeout    30s;

# Don't buffer API responses — send them to the client as they arrive
proxy_buffering off;
