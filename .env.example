# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# Public URL of the app (used in email links)
APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://app_user:changeme@localhost:5432/ironledger
# Used only by migration scripts (bypasses RLS)
DATABASE_ADMIN_URL=postgres://app_admin:changeme@localhost:5432/ironledger

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && cat private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
# Generate with: openssl rsa -in private.pem -pubout -out public.pem && cat public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
# Access token TTL in seconds (default: 15 minutes)
JWT_EXPIRES_IN=900
# Refresh token TTL in days (default: 30 days)
REFRESH_TOKEN_TTL_DAYS=30

# ── Email ─────────────────────────────────────────────────────────────────────
# Use Resend (https://resend.com) or SMTP
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@yourdomain.com
# Or use SMTP:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.ionos.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=changeme

# ── hCaptcha ──────────────────────────────────────────────────────────────────
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
# For local dev, use the always-pass test secret above

# ── HaveIBeenPwned (password check) ───────────────────────────────────────────
HIBP_API_KEY=REPLACE_ME

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Override defaults if needed
RATE_LIMIT_LOGIN=5          # per 15 min per IP
RATE_LIMIT_REGISTER=3       # per hour per IP
RATE_LIMIT_GLOBAL=120       # per minute per user

# ── Catalogue (game data) ──────────────────────────────────────────────────────
# Game data (assets, moves, oracles) is bundled in apps/api/data/ — no config
# needed. Set CATALOGUE_PATH only if you want to override with a custom location.
# CATALOGUE_PATH=/path/to/custom/data

# ── SvelteKit web app (apps/web) ───────────────────────────────────────────────
# Internal URL the SvelteKit server uses to reach the Fastify API.
# In production, both run on the same machine so this stays localhost.
INTERNAL_API_URL=http://localhost:3000
# Public URL shown to users (for email links, CORS, etc.)
# APP_URL already covers the Fastify side; this is the web frontend origin:
WEB_URL=http://localhost:5173
