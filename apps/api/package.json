{
  "name": "@ironledger/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev":           "node --env-file=../../.env --watch --import tsx/esm src/main.ts",
    "build":         "tsc --project tsconfig.json",
    "start":         "node dist/main.js",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "lint":          "eslint src tests --ext .ts",
    "migrate":       "node --env-file=../../.env --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "fastify":              "^5.2.1",
    "@fastify/helmet":      "^13.0.0",
    "@fastify/cors":        "^10.0.2",
    "@fastify/cookie":      "^11.0.2",
    "@fastify/rate-limit":  "^10.2.1",
    "drizzle-orm":          "^0.39.3",
    "postgres":             "^3.4.5",
    "ioredis":              "^5.4.2",
    "argon2":               "^0.41.1",
    "jose":                 "^5.9.6",
    "zod":                  "^3.24.1",
    "nodemailer":           "^6.9.16",
    "resend":               "^4.1.2",
    "pino":                 "^9.6.0",
    "pino-pretty":          "^13.0.0"
  },
  "devDependencies": {
    "typescript":           "^5.7.3",
    "tsx":                  "^4.19.2",
    "drizzle-kit":          "^0.30.4",
    "vitest":               "^3.0.6",
    "@vitest/coverage-v8":  "^3.0.6",
    "supertest":            "^7.0.0",
    "@types/nodemailer":    "^6.4.17",
    "@types/supertest":     "^6.0.2",
    "eslint":               "^9.19.0"
  }
}
