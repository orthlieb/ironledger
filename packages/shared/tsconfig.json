{
  "compilerOptions": {
    "outDir":           "./dist",
    "rootDir":          "./src",
    "target":           "ES2022",
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "strict":           true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
